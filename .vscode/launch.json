{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug tar_demo",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tar-and-untar/output/tar_demo.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/tar-and-untar",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-tar-demo-debug"
        }
    ]
}
